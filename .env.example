# Google (console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Microsoft Azure (portal.azure.com → App registrations)
VITE_AZURE_CLIENT_ID=your_azure_client_id_here
VITE_AZURE_TENANT_ID=common

# OpenWeatherMap (openweathermap.org/api - free tier works)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here
VITE_WEATHER_CITY=Atlanta,US
